<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="worldpay_vt_popup_view_form" model="ir.ui.view">
        <field name="name">worldpay.vt.popup.form</field>
        <field name="model">worldpay.vt.popup</field>
        <field name="arch" type="xml">
            <form string="Pay by WorldPay Virtual Terminal" style="max-width: 1200px;">
                <group>
                    <field name="payment_page_html" readonly="1" nolabel="1" widget="html"/>
                </group>
                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
